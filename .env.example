# Backend to use for vision analysis: "claude" (cloud) or "ollama" (local, free)
BACKEND=claude

# --- Claude (Anthropic API) ---
# Get an API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Ollama (local, free) ---
# Run `ollama serve` and `ollama pull qwen2.5vl:7b` first.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b

# --- Sampling / curation defaults ---
# Frames per second to sample from the input video (0.5 = 1 frame every 2s)
SAMPLE_FPS=0.5
# How many frames per LLM call (balance speed vs. context)
FRAMES_PER_BATCH=16
# Drop detected events with importance below this (1-5)
MIN_IMPORTANCE=3
# Seconds to include before and after each detected event
PADDING_BEFORE=4
PADDING_AFTER=3
